# LLM for content drafting + the on-site advisor.
# The CMS drafting layer is provider-agnostic with fallback: it tries the
# preferred provider and falls back to the other, then to placeholder text.
#   CMS_LLM_PROVIDER = "openai" | "gemini"   (optional; preferred provider)
# OpenAI (uses fetch, no extra dependency):
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
# Gemini (also powers /api/advisor):
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_MODEL="gemini-3.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# AI-CMS providers (OPTIONAL). Leave unset to run fully mocked: the /api/cms
# pipeline then writes content to the local working tree and simulates the
# branch/preview. Set these to activate real GitHub commits + Netlify previews.
# ---------------------------------------------------------------------------

# GitHub: a fine-grained or classic token with "repo" (contents + pull_requests)
# scope on the target repo. GITHUB_REPO is "owner/name".
# GITHUB_TOKEN="ghp_xxx"
# GITHUB_REPO="HeyoB-ai/The-Garage"
# GITHUB_DEFAULT_BRANCH="main"

# Netlify: the site's subdomain, used to build Deploy-Preview URLs
# (https://deploy-preview-<PR>--<NETLIFY_SITE_NAME>.netlify.app).
# NETLIFY_SITE_NAME="the-garage"

# Supabase (OPTIONAL): persist commands + logs for durable history (step 5).
# Leave unset to use the in-memory store. Use the SERVICE ROLE key — server-side
# only, never in client code. Run supabase/migrations/0001_ai_cms.sql first.
# SUPABASE_URL="https://<project>.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
